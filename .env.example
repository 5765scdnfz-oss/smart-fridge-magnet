# MiMo credentials
MIMO_API_KEY=replace-with-local-secret
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic

# Flask runtime. A token is mandatory when SFM_HOST is not loopback.
SFM_HOST=127.0.0.1
SFM_PORT=5000
SFM_DEBUG=false
SFM_API_TOKEN=replace-with-random-demo-token

# Optional comma-separated browser origins. Native Android does not need CORS.
SFM_CORS_ORIGINS=

# Optional local runtime paths and logging level.
SFM_DATABASE_PATH=
SFM_LOG_DIR=
SFM_LOG_LEVEL=INFO
